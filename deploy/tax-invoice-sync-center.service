[Unit]
Description=Tax Invoice Sync Center
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/invoice-demo-batch-import
EnvironmentFile=/etc/tax-invoice-sync-center.env
ExecStart=/opt/invoice-demo-batch-import/.venv/bin/gunicorn --workers 2 --bind 0.0.0.0:5021 sync_center_wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
